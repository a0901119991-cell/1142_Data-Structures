public:
    int findLucky(vector<int>& arr) {
        // 題目限制數字最大為 500，設定501 的陣列
        // 初始化為 0
        vector<int> count(501, 0);

        // 統計每個數字出現的次數
        for (int num : arr) {
            count[num]++;
        }

        // 從 500 開始往回找（由大到小）
        // 這樣第一個符合條件的「幸運數字」就是最大的
        for (int i = 500; i >= 1; i--) {
            if (count[i] == i) {
                return i;
            }
        }

        // 如果迴圈跑完都沒找到，回傳 -1
        return -1;
    }
};
